{
  "name": "@viberevert/adapters",
  "version": "0.7.0-beta.0",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Fabio Marcello Salvadori <fabio@madeinpluto.com>",
  "description": "Read-only adapter contracts and hook-surface primitives for VibeRevert integrations (Cursor, Claude Code, Husky, Lefthook, direct hook, GitHub Action).",
  "homepage": "https://github.com/madeinplutofabio/vibe-revert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madeinplutofabio/vibe-revert.git",
    "directory": "packages/adapters"
  },
  "bugs": {
    "url": "https://github.com/madeinplutofabio/vibe-revert/issues"
  },
  "keywords": [
    "viberevert",
    "adapters",
    "installer",
    "cursor",
    "claude",
    "husky",
    "lefthook",
    "github-action",
    "mcp"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "js-yaml": "4.1.0"
  }
}
