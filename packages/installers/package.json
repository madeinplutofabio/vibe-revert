{
  "name": "@viberevert/installers",
  "version": "0.7.1-beta.1",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Fabio Marcello Salvadori <fabio@madeinpluto.com>",
  "description": "Non-destructive installer engine for VibeRevert integrations. Preview, apply, and uninstall under a per-repo lock with a pre-mutation recovery journal.",
  "homepage": "https://github.com/madeinplutofabio/vibe-revert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madeinplutofabio/vibe-revert.git",
    "directory": "packages/installers"
  },
  "bugs": {
    "url": "https://github.com/madeinplutofabio/vibe-revert/issues"
  },
  "keywords": [
    "viberevert",
    "installer",
    "adapters",
    "integrations",
    "atomic",
    "safety"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@viberevert/adapters": "workspace:*",
    "diff": "9.0.0",
    "zod": "4.4.3"
  }
}
