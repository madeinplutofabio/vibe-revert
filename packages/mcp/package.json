{
  "name": "@viberevert/mcp",
  "version": "0.7.1-beta.0",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Fabio Marcello Salvadori <fabio@madeinpluto.com>",
  "description": "Model Context Protocol server for VibeRevert.",
  "homepage": "https://github.com/madeinplutofabio/vibe-revert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madeinplutofabio/vibe-revert.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/madeinplutofabio/vibe-revert/issues"
  },
  "keywords": [
    "viberevert",
    "mcp",
    "model-context-protocol"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@viberevert/cli-commands": "workspace:*",
    "@viberevert/core": "workspace:*",
    "@viberevert/session-format": "workspace:*",
    "zod": "4.4.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
