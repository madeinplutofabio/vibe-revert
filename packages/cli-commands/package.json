{
  "name": "@viberevert/cli-commands",
  "version": "0.7.0-beta.0",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Fabio Marcello Salvadori <fabio@madeinpluto.com>",
  "description": "Command implementations and in-process Clipanion harness for the VibeRevert CLI.",
  "homepage": "https://github.com/madeinplutofabio/vibe-revert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madeinplutofabio/vibe-revert.git",
    "directory": "packages/cli-commands"
  },
  "bugs": {
    "url": "https://github.com/madeinplutofabio/vibe-revert/issues"
  },
  "keywords": [
    "viberevert",
    "cli",
    "clipanion",
    "commands"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@viberevert/adapters": "workspace:*",
    "@viberevert/checks": "workspace:*",
    "@viberevert/core": "workspace:*",
    "@viberevert/git": "workspace:*",
    "@viberevert/installers": "workspace:*",
    "@viberevert/reporters": "workspace:*",
    "@viberevert/session-format": "workspace:*",
    "clipanion": "3.2.1",
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@types/picomatch": "4.0.2"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
