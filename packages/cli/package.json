{
  "name": "viberevert",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "author": "Fabio Marcello Salvadori <fabio@madeinpluto.com>",
  "description": "The safety belt for vibe coding. Visible, reversible, and safer AI coding sessions.",
  "homepage": "https://github.com/madeinplutofabio/vibe-revert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madeinplutofabio/vibe-revert.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/madeinplutofabio/vibe-revert/issues"
  },
  "keywords": [
    "ai",
    "coding",
    "safety",
    "checkpoint",
    "rollback",
    "claude-code",
    "cursor",
    "codex"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "viberevert": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@viberevert/cli-commands": "workspace:*",
    "@viberevert/mcp": "workspace:*",
    "clipanion": "3.2.1"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/finalize-bin.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
