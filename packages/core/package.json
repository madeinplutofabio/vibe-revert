{
  "name": "@viberevert/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "author": "Fabio Marcello Salvadori <fabio@madeinpluto.com>",
  "description": "Session, config, paths, and redaction primitives for VibeRevert.",
  "homepage": "https://github.com/madeinplutofabio/vibe-revert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madeinplutofabio/vibe-revert.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/madeinplutofabio/vibe-revert/issues"
  },
  "keywords": [
    "viberevert",
    "session",
    "config",
    "redaction"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@viberevert/session-format": "workspace:*",
    "ulid": "3.0.2",
    "yaml": "2.8.3",
    "zod": "4.4.1"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
