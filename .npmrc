# Enforce pnpm as the package manager, and require the exact version
# declared in package.json's "packageManager" field.
package-manager-strict=true
package-manager-strict-version=true

# Keep installs maximally strict: no hoisting, isolated linker.
hoist=false
node-linker=isolated

# Save exact dependency versions.
save-prefix=

# Refuse installs when dependency engine requirements are incompatible.
engine-strict=true

# Do not auto-install peer dependencies.
auto-install-peers=false
