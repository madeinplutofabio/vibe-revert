# dependencies
node_modules/

# build output
dist/
build/
.next/
*.tsbuildinfo
# Belt-and-braces: prevent stray TypeScript build artifacts from landing
# in src/ if a future tsc misconfiguration accidentally emits them there.
# All packages output to dist/, not src/, so any of these in src/ is wrong.
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# test artifacts
coverage/
*.log

# editors / OS
.DS_Store
.idea/
.vscode/

# local viberevert state (self-dogfooding)
.viberevert/

# pnpm
.pnpm-store/

# env
.env
.env.local
.env.*.local

# packed tarballs (smoke-test, M H release prep)
*.tgz

# local-only planning docs (not for the public repo)
VibeRevert_CLI_Detailed_Build_Plan.md
VibeRevert_Project_Roadmap_Licensing.md
full_beta_plan.md

# Local-only milestone plan archives
plans/
