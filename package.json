{
  "name": "viberevert-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "author": "Fabio Marcello Salvadori <fabio@madeinpluto.com>",
  "homepage": "https://github.com/madeinplutofabio/vibe-revert#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madeinplutofabio/vibe-revert.git"
  },
  "bugs": {
    "url": "https://github.com/madeinplutofabio/vibe-revert/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "check:dependency-policy": "tsx scripts/check-dependency-policy.ts",
    "check:license-audit": "tsx scripts/regen-license-audit.ts --check",
    "regen-goldens": "tsx scripts/regen-goldens.ts",
    "regen:license-audit": "tsx scripts/regen-license-audit.ts",
    "refresh:license-metadata": "tsx scripts/refresh-license-metadata.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@changesets/cli": "2.31.0",
    "@types/node": "22.20.1",
    "tar": "7.5.21",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "yaml": "2.8.3"
  }
}
